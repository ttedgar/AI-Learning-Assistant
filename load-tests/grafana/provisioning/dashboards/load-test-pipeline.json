        "y": 44,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 8,
      "title": "End-to-End Pipeline Duration \u2014 Average",
      "description": "Average time from document upload to terminal state (DONE/FAILED). Micrometer Timer is a summary type \u2014 average = sum/count rate over 1m window.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(document_e2e_duration_seconds_sum{application=\"backend\", status=\"DONE\"}[1m]) / rate(document_e2e_duration_seconds_count{application=\"backend\", status=\"DONE\"}[1m])",
          "legendFormat": "Avg e2e duration (DONE)"
        },
        {
          "refId": "B",
          "expr": "rate(document_e2e_duration_seconds_count{application=\"backend\", status=\"DONE\"}[1m])",
          "legendFormat": "Throughput (docs/s)"
        },
        {
          "refId": "C",
          "expr": "rate(document_processing_duration_seconds_sum{application=\"backend\", status=\"DONE\"}[1m]) / rate(document_processing_duration_seconds_count{application=\"backend\", status=\"DONE\"}[1m])",
          "legendFormat": "Avg processing duration (IN_PROGRESS\u2192DONE)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
