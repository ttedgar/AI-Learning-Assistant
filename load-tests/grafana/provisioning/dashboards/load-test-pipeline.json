    {
      "id": 33,
      "title": "Consumer Capacity \u2014 document.processing",
      "description": "Fraction of time the worker consumer is active (0=idle, 1=fully utilized). Should sit at ~1.0 while the queue has messages. Drops to 0 when queue is empty. Useful for seeing when the drain completes.",
