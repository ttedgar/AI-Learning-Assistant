{
  "uid": "load-test-pipeline",
  "title": "Load Test \u2014 Pipeline Overview",
  "description": "Queue depth, worker performance, AI latency, and backend metrics for load test runs.",
  "tags": [
    "loadtest"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 20,
      "title": "Queue Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "title": "Total Messages Ready",
      "description": "Sum of ready messages across all queues. The number to watch during a test run.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rabbitmq_detailed_queue_messages_ready)",
          "legendFormat": "Total ready"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 22,
      "title": "Messages Published / s",
      "description": "Rate at which messages are published into exchanges. Driven by the upload script during the upload phase.",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(rabbitmq_global_messages_received_total[30s])",
          "legendFormat": "Published / s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 23,
      "title": "Messages Routed to Queues / s",
      "description": "Rate at which messages are routed from exchanges into queues. Should closely mirror publish rate \u2014 a gap indicates routing issues.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(rabbitmq_global_messages_routed_total[30s])",
          "legendFormat": "Routed / s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 1,
      "title": "Queue Depth \u2014 All Queues",
      "description": "Ready messages per queue over time. document.processing is the main drain curve. DLQ should stay at 0 on happy path runs.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rabbitmq_detailed_queue_messages_ready{queue=\"document.processing\"}",
          "legendFormat": "document.processing"
        },
        {
          "refId": "B",
          "expr": "rabbitmq_detailed_queue_messages_ready{queue=\"document.processed\"}",
          "legendFormat": "document.processed"
        },
        {
          "refId": "C",
          "expr": "rabbitmq_detailed_queue_messages_ready{queue=\"document.processing.dlq\"}",
          "legendFormat": "document.processing.dlq"
        },
        {
          "refId": "D",
          "expr": "rabbitmq_detailed_queue_messages_ready{queue=\"document.status\"}",
          "legendFormat": "document.status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "document.processing.dlq \u26a0\ufe0f"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "document.processing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "Message Publish Rate vs Deliver Rate",
      "description": "Gap between publish and deliver rate = queue backpressure. If publish > deliver the queue grows.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(rabbitmq_global_messages_received_total[30s])",
          "legendFormat": "Publish rate (msg/s)"
        },
        {
          "refId": "B",
          "expr": "irate(rabbitmq_global_messages_delivered_total[30s])",
          "legendFormat": "Deliver rate (msg/s)"
        },
        {
          "refId": "C",
          "expr": "irate(rabbitmq_global_messages_acknowledged_total[30s])",
          "legendFormat": "Ack rate (msg/s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "title": "Unacknowledged Messages (In-Flight)",
      "description": "Messages the worker has received but not yet acked. Should equal QOS setting during active processing.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rabbitmq_detailed_queue_messages_unacked{queue=\"document.processing\"}",
          "legendFormat": "Unacked (document.processing)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "title": "Worker Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 4,
      "title": "AI Call Latency \u2014 Average per Operation",
      "description": "Average latency per AI call type (summarize/flashcards/quiz). Micrometer Timer is summary type \u2014 shows average = sum/count rate. With stub, this shows pipeline overhead beyond the stub delay.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 16,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ai_call_latency_seconds_sum{application=\"worker\"}[1m]) / rate(ai_call_latency_seconds_count{application=\"worker\"}[1m])",
          "legendFormat": "Avg latency \u2014 {{operation}}"
        },
        {
          "refId": "B",
          "expr": "ai_call_latency_seconds_max{application=\"worker\"}",
          "legendFormat": "Max \u2014 {{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "title": "Retries & DLQ Events",
      "description": "Retry counter shows processing failures being retried. DLQ routed counter shows messages that exhausted all retries.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 27,
        "w": 8,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(document_retry_count_total{application=\"worker\"}[1m])",
          "legendFormat": "Retry rate"
        },
        {
          "refId": "B",
          "expr": "rate(document_dlq_routed_total{application=\"worker\"}[1m])",
          "legendFormat": "DLQ routed rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "DLQ routed rate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "title": "Worker JVM Heap",
      "description": "Heap used vs committed. Watch for steady growth (leak) or sharp spikes (large PDFs in memory).",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{application=\"worker\", area=\"heap\"}",
