# ============================================================
# Root .env.example — copy to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (safe for frontend; only in VITE_ vars)
SUPABASE_ANON_KEY=your-anon-key

# Service role key (backend only — full DB access, never expose to frontend)
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT secret for verifying Supabase-issued JWTs
# Found at: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase direct DB connection (for Liquibase migrations from backend)
# Found at: Supabase Dashboard → Settings → Database → Connection string (direct)
SUPABASE_DB_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# ── RabbitMQ ─────────────────────────────────────────────────
# For local Docker: defaults to guest/guest
# For Railway: copy from Railway RabbitMQ plugin → Variables tab
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Internal API Key ─────────────────────────────────────────
# Shared secret between worker and ai-service.
# Generate with: openssl rand -hex 32
# Production: replace with mTLS
INTERNAL_API_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Gemini API ────────────────────────────────────────────────
# Google AI Studio → API keys
GEMINI_API_KEY=your-gemini-api-key

# ── Langfuse (LLM Observability) ─────────────────────────────
# Optional — ai-service runs without these, but traces are very useful.
# https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
