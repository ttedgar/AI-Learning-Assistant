# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# OS
.DS_Store
Thumbs.db

# Claude worktrees
.claude/worktrees/

# Environment files — never commit secrets
.env
backend/.env
worker/.env
ai-service/.env
frontend/.env

# Test PDFs — large binaries, not source artifacts
*.pdf

# Claude Code local project settings (machine-specific; contains MCP permissions)
.claude/settings.local.json

# Load test raw results — committed summaries (*.md) are not ignored
load-tests/results/**/*.json
load-tests/results/**/*.csv
.wslconfig_temp

# Temp files left by sed (from RLS migration session)
sed*
