# AI Service Configuration

# Internal API key — workers must send this in X-Internal-Api-Key header
# Production: replace with mTLS certificate-based auth
INTERNAL_API_KEY=change-me-in-production

# Google Gemini API key (passed as GEMINI_API_KEY from docker-compose)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use
# See: https://ai.google.dev/gemini-api/docs/models/gemini
GEMINI_MODEL=gemini-2.5-flash

# Token threshold above which long-document chunking kicks in
# Documents exceeding this character count trigger the map-reduce summarization path
LONG_DOC_CHAR_THRESHOLD=10000

# Number of characters per chunk when splitting long documents
CHUNK_SIZE=4000

# Chunk overlap to preserve context across boundaries
CHUNK_OVERLAP=200

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Langfuse observability (optional — service runs without these)
# Get keys from: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
