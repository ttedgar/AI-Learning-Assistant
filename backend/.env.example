# Backend environment variables.
# These are injected via docker-compose or Railway environment variables.
# When running locally outside Docker, copy to backend/.env and use
# spring-dotenv or set via IntelliJ run configuration.

SPRING_DATASOURCE_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password

SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

INTERNAL_API_KEY=change-me-generate-with-openssl-rand-hex-32
