# Frontend environment variables.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Never put service-role keys or secrets here.

VITE_BACKEND_URL=http://localhost:8080
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dev auth bypass — set to true to skip Google OAuth (for automated testing only).
# The backend must be running with SPRING_PROFILES_ACTIVE=dev for this to work.
# Never set VITE_DEV_AUTH=true in production.
VITE_DEV_AUTH=false
VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000001
VITE_DEV_USER_EMAIL=dev@local.test
